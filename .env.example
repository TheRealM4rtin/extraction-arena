# Vision model API keys (baked into the frontend at Docker build time).
# Copy this file to ".env" and fill in your real keys, then run:
#   cp .env.example .env && docker compose up --build
VITE_ZAI_API_KEY=your_zai_key_here
VITE_OPENAI_API_KEY=sk-your_openai_key_here

# Optional: override the Docling model preset used inside the backend container.
# Docker cannot use MLX (Apple-Silicon-only), so valid container values are:
#   smoldocling (default) | granitedocling
DOCLING_MODEL=smoldocling
