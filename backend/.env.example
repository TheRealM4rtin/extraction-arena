# Optional: backend port override
PORT=3001

# Optional: point to a Python environment with Docling installed
DOCLING_PYTHON_PATH=python3

# Optional: override the worker script path
# DOCLING_WORKER_PATH=/absolute/path/to/docling_worker.py

# Local Docling VLM model preset. Supported values:
# - smoldocling_mlx (default on bare-metal M1 Pro, fastest)
# - granitedocling_mlx
# - smoldocling      (CPU/PyTorch — use in Docker or non-Apple hardware)
# - granitedocling   (CPU/PyTorch)
# Note: the *_mlx variants only work outside Docker (MLX needs bare-metal
# Apple Silicon). The non-mlx variants work everywhere, including containers.
DOCLING_MODEL=smoldocling_mlx

# Optional: worker timeout in milliseconds
DOCLING_TIMEOUT_MS=600000
