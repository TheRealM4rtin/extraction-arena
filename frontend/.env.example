# Frontend (Vite reads these from frontend/.env). The VITE_ prefix is required:
# Vite only exposes VITE_-prefixed vars to the browser bundle. Both providers
# are called directly from the browser, so these intentionally ship to the client.
VITE_ZAI_API_KEY=your_zai_key_here
VITE_OPENAI_API_KEY=sk-your_openai_key_here
