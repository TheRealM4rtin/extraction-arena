# Frontend (Vite reads these from frontend/.env). The VITE_ prefix is required:
# Vite only exposes VITE_-prefixed vars to the browser bundle. Keys are forwarded
# through the same-origin /api/llm proxy (CORS bypass), so these intentionally
# ship to the client.
VITE_ZAI_API_KEY=your_zai_key_here
VITE_OPENAI_API_KEY=sk-your_openai_key_here
VITE_XAI_API_KEY=xai-your_xai_key_here
