{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://extraction-arena.local/schemas/rescue-sheet-ev-v1.1.json",
  "title": "Rescue Sheet EV v1.1",
  "description": "Canonical rich rescue-sheet contract (ISO-17840-style domain body + app envelope). No coordinates: evidence is page-level; locations are textual.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "record_id",
    "lifecycle_status",
    "review",
    "document",
    "vehicle",
    "responder_information",
    "evidence",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["rescue-sheet-ev-v1.1", "rescue-sheet-ev-v1.0"]
    },
    "record_id": { "type": "string", "minLength": 1 },
    "lifecycle_status": {
      "enum": ["raw", "draft", "validated", "reviewed", "published", "rejected", "legacy"]
    },
    "review": {
      "type": "object",
      "additionalProperties": true,
      "required": ["review_required", "review_status", "reviewed_by", "reviewed_at"],
      "properties": {
        "review_required": { "type": "boolean" },
        "review_status": {
          "enum": ["pending", "approved", "rejected", "changes_requested"]
        },
        "reviewed_by": { "type": ["string", "null"] },
        "reviewed_at": { "type": ["string", "null"] }
      }
    },
    "standard_reference": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "document": {
      "type": "object",
      "additionalProperties": true,
      "required": ["document_type", "source_pages"],
      "properties": {
        "document_type": { "const": "rescue_sheet" },
        "document_id": { "type": ["string", "null"] },
        "document_version": { "type": ["string", "null"] },
        "sheet_page_count": { "type": ["integer", "null"] },
        "source_pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["page_id", "page_number"],
            "properties": {
              "page_id": { "type": "string", "minLength": 1 },
              "page_number": { "type": "integer", "minimum": 1 },
              "filename": { "type": ["string", "null"] },
              "sheet_page_number": { "type": ["integer", "null"] },
              "attachment_id": { "type": ["string", "null"] },
              "attachment_filename": { "type": ["string", "null"] },
              "printed_page_number": { "type": ["string", "null"] },
              "content_summary": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "vehicle": {
      "type": "object",
      "additionalProperties": true,
      "required": ["manufacturer", "model", "propulsion"],
      "properties": {
        "manufacturer": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "model_year": { "type": ["string", "null"] },
        "model_year_start": { "type": ["integer", "null"] },
        "model_year_end": { "type": ["integer", "null"] },
        "vehicle_class": { "type": ["string", "null"] },
        "body_style": { "type": ["string", "null"] },
        "door_count": { "type": ["integer", "null"] },
        "seating_capacity": { "type": ["integer", "null"] },
        "propulsion": {
          "type": "object",
          "additionalProperties": true,
          "required": ["primary_energy_source"],
          "properties": {
            "primary_energy_source": { "type": "string", "minLength": 1 },
            "secondary_energy_sources": {
              "type": "array",
              "items": { "type": "string" }
            },
            "drivetrain": { "type": ["string", "null"] },
            "door_count": { "type": ["integer", "null"] },
            "high_voltage_systems": {
              "type": ["array", "null"],
              "items": { "type": "object", "additionalProperties": true }
            },
            "low_voltage_systems": {
              "type": ["array", "null"],
              "items": { "type": "object", "additionalProperties": true }
            }
          }
        }
      }
    },
    "responder_information": {
      "type": "object",
      "additionalProperties": true
    },
    "vehicle_layout": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "warnings": {
      "type": ["array", "null"],
      "items": { "type": "object", "additionalProperties": true }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["evidence_id", "source_file_id", "sheet_page_number"],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "source_file_id": { "type": "string", "minLength": 1 },
          "sheet_page_number": { "type": "integer", "minimum": 1 },
          "source_text": { "type": ["string", "null"] },
          "extraction_method": {
            "enum": ["direct_text", "diagram_inference", "inferred", "manual"]
          },
          "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "verification_status": {
            "enum": ["human_verified", "human_review_required", "auto_extracted", "unverified"]
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "legacy_fields": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["value"]
      }
    },
    "high_voltage_systems": { "type": ["object", "null"], "additionalProperties": true },
    "pyrotechnic_devices": { "type": ["object", "null"], "additionalProperties": true },
    "fire": { "type": ["object", "null"], "additionalProperties": true },
    "submersion": { "type": ["object", "null"], "additionalProperties": true },
    "towing_transport_storage": { "type": ["object", "null"], "additionalProperties": true }
  }
}
